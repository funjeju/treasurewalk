rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function ownsFamily(fid) {
      return signedIn() &&
        get(/databases/$(database)/documents/families/$(fid)).data.ownerUid == request.auth.uid;
    }

    match /families/{fid} {
      // 가족 문서: 소유자만. 최초 생성은 ownerUid==본인 + 아직 존재하지 않을 때 허용.
      allow read, write: if ownsFamily(fid) ||
        (signedIn() &&
         request.resource.data.ownerUid == request.auth.uid &&
         !exists(/databases/$(database)/documents/families/$(fid)));

      // 하위 모든 문서: 가족 소유자만 (docs/03 §4, docs/07 §B 가족 격리)
      match /{document=**} {
        allow read, write: if ownsFamily(fid);
      }
    }

    // collectionGroup('claims') 쿼리: claim 문서에 familyId 필드를 두고 소유 검증.
    match /{path=**}/claims/{claimId} {
      allow read: if signedIn() && ownsFamily(resource.data.familyId);
    }
  }
}
