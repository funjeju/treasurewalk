rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // 자녀 세션: 커스텀 토큰 claim (role=child, familyId)
    function isChildOf(fid) {
      return signedIn()
        && request.auth.token.role == 'child'
        && request.auth.token.familyId == fid;
    }

    match /families/{fid} {
      // 최상위 가족 문서: 부모는 resource.data 로 쿼리 증명, 자녀는 claim 으로 get 허용.
      allow read: if (signedIn() && resource.data.ownerUid == request.auth.uid)
        || isChildOf(fid);
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      // 하위 문서: 부모 소유자 또는 같은 가족 자녀.
      match /{document=**} {
        allow read, write: if (signedIn() &&
          get(/databases/$(database)/documents/families/$(fid)).data.ownerUid == request.auth.uid)
          || isChildOf(fid);
      }
    }

    // 자녀 참여 코드 매핑: 서버(admin)만 읽음. 부모는 자기 가족 코드만 생성/삭제.
    match /joinCodes/{code} {
      allow read: if false;
      allow create: if signedIn() &&
        get(/databases/$(database)/documents/families/$(request.resource.data.familyId)).data.ownerUid == request.auth.uid;
      allow delete: if signedIn() &&
        get(/databases/$(database)/documents/families/$(resource.data.familyId)).data.ownerUid == request.auth.uid;
    }
  }
}
