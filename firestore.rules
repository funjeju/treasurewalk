rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /families/{fid} {
      // 최상위 가족 문서: resource.data 직접 참조 →
      // 컬렉션 쿼리(where ownerUid == uid, list)도 규칙 증명 가능 (get() 방식은 쿼리에서 거부됨).
      allow read: if signedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerUid == request.auth.uid;

      // 하위 모든 문서(children/treasures/claims/activity): 부모 가족 소유자만 (가족 격리).
      // get(parent) 는 쿼리 전체에 대한 상수 검사이므로 list/get 모두 허용됨.
      match /{document=**} {
        allow read, write: if signedIn() &&
          get(/databases/$(database)/documents/families/$(fid)).data.ownerUid == request.auth.uid;
      }
    }
  }
}
